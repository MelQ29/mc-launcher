{
  "name": "eclipse-fantasy-launcher",
  "productName": "EclipseFantasy",
  "version": "0.2.0",
  "description": "Cross-platform multi-modpack Minecraft launcher (Eclipse Fantasy + FTB Summermon)",
  "main": "dist/main/main/main.js",
  "author": {
    "name": "EclipseFantasy",
    "email": "noreply@example.com"
  },
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "tsc -p tsconfig.renderer.json && node scripts/copy-renderer-assets.js",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "dist": "npm run build && electron-builder --publish=never",
    "dist:win": "npm run build && electron-builder --win --x64 --publish=never",
    "dist:linux": "npm run build && electron-builder --linux --x64 --publish=never",
    "lint": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test --test-reporter=spec 'dist-tests/tests/**/*.test.js'",
    "test:watch": "tsc -p tsconfig.test.json --watch & node --test --watch 'dist-tests/tests/**/*.test.js'"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0"
  },
  "build": {
    "appId": "com.eclipsefantasy.launcher",
    "productName": "EclipseFantasy",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "build/icon.*",
      "config/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "build",
        "to": "build",
        "filter": [
          "icon.*"
        ]
      },
      {
        "from": "config",
        "to": "config"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "shortcutName": "${productName}",
      "uninstallDisplayName": "${productName} ${version}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "MelQ29",
      "repo": "mc-launcher",
      "vPrefixedTagName": false
    }
  }
}
