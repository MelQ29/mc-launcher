{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-tests",
    "rootDir": ".",
    "module": "CommonJS",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": ["tests/**/*", "src/**/*"],
  "exclude": ["src/renderer/**/*", "node_modules", "dist", "dist-tests", "release"]
}
